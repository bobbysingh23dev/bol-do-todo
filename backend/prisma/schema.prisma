generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?
  type         String   @default("task")
  personName   String?
  amount       Int?
  dueDateText  String?
  dueAt        DateTime?
  status       String   @default("pending")
  sourceText   String?
  generatedMsg String?
  audioPath    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}