PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bol_do_dev?schema=public"
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:4000

# Nodemailer SMTP (optional — dev mode logs emails to console if unset)
EMAIL_FROM=BolDo <your-verified-sender@example.com>
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-key-here
